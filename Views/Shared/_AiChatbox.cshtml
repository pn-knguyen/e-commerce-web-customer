<aside class="chat-dock" aria-label="Kênh hỗ trợ TechStore">
    <section class="chat-widget chat-widget--support" id="support-chat" aria-label="Nhắn trực tiếp với admin">
        <div class="chat-widget__panel" id="support-chat-panel" aria-hidden="true">
            <header class="chat-widget__header">
                <div class="chat-widget__header-copy">
                    <strong>Nhắn admin</strong>
                    <span id="support-chat-status">Đang kết nối</span>
                </div>
                <button class="chat-widget__close" id="support-chat-close" type="button" aria-label="Đóng chat admin">×</button>
                <nav class="chat-widget__channel-switch" aria-label="Chọn kênh hỗ trợ">
                    <button type="button" data-chat-channel-switch="support" aria-pressed="true">
                        <span class="chat-widget__channel-state" data-support-presence aria-hidden="true"></span>
                        <span>Admin</span>
                        <span class="chat-widget__channel-badge" data-support-unread hidden aria-hidden="true">0</span>
                    </button>
                    <button type="button" data-chat-channel-switch="ai" aria-pressed="false">
                        <span class="chat-widget__channel-state is-online" aria-hidden="true"></span>
                        <span>AI</span>
                    </button>
                </nav>
            </header>

            <div class="chat-widget__messages" id="support-chat-messages" role="log" aria-live="polite"></div>

            <form class="chat-widget__form" id="support-chat-form" novalidate>
                <label class="sr-only" for="support-chat-input">Nhập tin nhắn gửi admin</label>
                <textarea id="support-chat-input" maxlength="1000" rows="1"
                          placeholder="Nhắn cho admin TechStore..." required></textarea>
                <button type="submit" aria-label="Gửi tin nhắn cho admin">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M4 4l17 8-17 8 3-8-3-8zm3 8h14" />
                    </svg>
                </button>
            </form>
        </div>

        <button class="chat-widget__toggle chat-widget__toggle--support" id="support-chat-toggle" type="button"
                aria-controls="support-chat-panel" aria-expanded="false" aria-label="Mở chat admin">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21 12a8 8 0 0 1-8 8H7l-4 2 1.5-4.2A8.6 8.6 0 0 1 3 12a9 9 0 1 1 18 0Z" />
            </svg>
            <span class="chat-widget__toggle-badge" data-support-unread hidden aria-hidden="true">0</span>
        </button>
    </section>

    <section class="chat-widget chat-widget--ai" id="ai-assistant" aria-label="Trợ lý AI TechStore">
        <div class="chat-widget__panel chat-widget__panel--ai" id="ai-assistant-panel" aria-hidden="true">
            <header class="chat-widget__header chat-widget__header--ai">
                <div class="chat-widget__header-copy">
                    <strong>Trợ lý AI</strong>
                    <span id="ai-assistant-status">Sẵn sàng tư vấn</span>
                </div>
                <button class="chat-widget__close" id="ai-assistant-close" type="button" aria-label="Đóng trợ lý AI">×</button>
                <nav class="chat-widget__channel-switch" aria-label="Chọn kênh hỗ trợ">
                    <button type="button" data-chat-channel-switch="support" aria-pressed="false">
                        <span class="chat-widget__channel-state" data-support-presence aria-hidden="true"></span>
                        <span>Admin</span>
                        <span class="chat-widget__channel-badge" data-support-unread hidden aria-hidden="true">0</span>
                    </button>
                    <button type="button" data-chat-channel-switch="ai" aria-pressed="true">
                        <span class="chat-widget__channel-state is-online" aria-hidden="true"></span>
                        <span>AI</span>
                    </button>
                </nav>
            </header>

            <div class="chat-widget__messages" id="ai-assistant-messages" role="log" aria-live="polite"></div>

            <div class="chat-widget__loading" id="ai-assistant-loading" hidden>
                <span></span><span></span><span></span>
                <span class="sr-only">AI đang trả lời</span>
            </div>

            <form class="chat-widget__form" id="ai-assistant-form" novalidate>
                <label class="sr-only" for="ai-assistant-input">Nhập câu hỏi cho AI</label>
                <textarea id="ai-assistant-input" maxlength="1000" rows="1"
                          placeholder="Hỏi AI về sản phẩm..." required></textarea>
                <button type="submit" aria-label="Gửi câu hỏi cho AI">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M4 4l17 8-17 8 3-8-3-8zm3 8h14" />
                    </svg>
                </button>
            </form>
        </div>

        <button class="chat-widget__toggle chat-widget__toggle--ai" id="ai-assistant-toggle" type="button"
                aria-controls="ai-assistant-panel" aria-expanded="false" aria-label="Mở trợ lý AI">
            <span class="ai-robot-greeting" data-ai-greeting aria-hidden="true">Xin chào, mình là AI TechStore</span>
            <span class="ai-robot-3d" aria-hidden="true">
                <img class="ai-robot-3d__image"
                     src="~/images/ai-assistant/techstore-ai-robot-cutout.png"
                     alt=""
                     loading="eager"
                     decoding="async" />
                <span class="ai-robot-3d__wave"></span>
            </span>
        </button>
    </section>
</aside>
