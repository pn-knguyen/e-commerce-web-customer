@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_AuthLayout";
}

<div class="auth-page">
    <section class="auth-brand-panel" aria-labelledby="brand-heading">
        <a class="auth-home-link" asp-controller="Home" asp-action="Index" aria-label="Về trang chủ TechStore">
            <img src="~/images/logo-techstore.svg" alt="TechStore" width="250" height="75" />
        </a>

        <div class="auth-brand-copy">
            <p class="auth-eyebrow">TechStore membership</p>
            <h1 id="brand-heading">Công nghệ cho cuộc sống.</h1>
            <p>Mua sắm nhanh hơn, quản lý đơn hàng gọn hơn và nhận ưu đãi dành riêng cho bạn.</p>
        </div>

        <div class="auth-promises" aria-label="Cam kết của TechStore">
            <span>Chính hãng 100%</span>
            <span>Giao nhanh toàn quốc</span>
            <span>Đổi trả minh bạch</span>
        </div>

        <img class="auth-brand-watermark" src="~/images/logo-techstore-icon.svg" alt="" aria-hidden="true" />
    </section>

    <section class="auth-form-panel" aria-labelledby="login-heading">
        <div class="auth-form-shell">
            <div class="auth-switch">
                <span>Chưa có tài khoản?</span>
                <a asp-controller="Account" asp-action="Register">Đăng ký</a>
            </div>

            <header class="auth-form-header">
                <p class="auth-form-kicker">Chào mừng trở lại</p>
                <h2 id="login-heading">Đăng nhập TechStore</h2>
                <p>Tiếp tục hành trình mua sắm của bạn.</p>
            </header>

            @if (TempData["AuthNotice"] is string notice)
            {
                <div class="auth-notice" role="status">@notice</div>
            }

            @if (TempData["AuthSuccess"] is string success)
            {
                <div class="auth-success-alert" role="status">@success</div>
            }

            <div id="authErrorMessage" class="auth-notice" style="display: none;" role="status"></div>
            <div id="authSuccessMessage" class="auth-success-alert" style="display: none;" role="status"></div>

            <div class="auth-social-grid">
                <button type="button" class="auth-social-button" onclick="handleGoogleLogin()">
                    <span class="social-icon-wrap" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                    </span>
                    <span>Google</span>
                </button>
                <button type="button" class="auth-social-button" onclick="handleFacebookLogin()">
                    <span class="social-icon-wrap social-icon-facebook" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="#1877F2"/>
                            <path d="M16.671 15.543l.532-3.47h-3.328v-2.25c0-.949.465-1.874 1.956-1.874h1.513V4.996s-1.374-.235-2.686-.235c-2.741 0-4.533 1.662-4.533 4.669v2.643H7.078v3.47h3.047v8.385a12.09 12.09 0 003.75 0v-8.385h2.796z" fill="#ffffff"/>
                        </svg>
                    </span>
                    <span>Facebook</span>
                </button>
            </div>

            <div class="auth-divider"><span>hoặc đăng nhập bằng email</span></div>

            <div id="passwordFormContainer">
                <form id="loginForm" class="auth-form" onsubmit="handleEmailLogin(event)">
                    <div asp-validation-summary="ModelOnly" class="auth-validation-summary" role="alert"></div>

                    <div class="auth-field">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" type="email" autocomplete="email" placeholder="ban@example.com" />
                        <span asp-validation-for="Email"></span>
                    </div>

                    <div class="auth-field">
                        <div class="auth-label-row">
                            <label asp-for="Password"></label>
                            <a asp-action="ForgotPassword" class="auth-forgot-link">Quên mật khẩu?</a>
                        </div>
                        <div class="auth-password-control">
                            <input asp-for="Password" autocomplete="current-password" placeholder="Nhập mật khẩu" />
                            <button type="button" class="auth-password-toggle" data-password-toggle="Password" aria-label="Hiện mật khẩu">Hiện</button>
                        </div>
                        <span asp-validation-for="Password"></span>
                    </div>

                    <label class="auth-checkbox">
                        <input asp-for="RememberMe" />
                        <span>Ghi nhớ đăng nhập trên thiết bị này</span>
                    </label>

                    <button type="submit" class="auth-submit-button">Đăng nhập</button>
                </form>
                
                <div style="margin-top: 16px; text-align: center; display: flex; flex-direction: column; gap: 8px;">
                    <button type="button" onclick="showMagicLinkAuth()" style="background: none; border: none; color: #18181b; font-weight: 600; font-size: 14px; cursor: pointer; text-decoration: underline;">Đăng nhập không cần mật khẩu (Magic Link)</button>
                    <button type="button" onclick="showPhoneAuth()" style="background: none; border: none; color: #18181b; font-weight: 600; font-size: 14px; cursor: pointer; text-decoration: underline;">Đăng nhập bằng Số điện thoại (SMS)</button>
                </div>
            </div>

            <div id="magicLinkFormContainer" style="display: none;">
                <form id="magicLinkForm" class="auth-form" onsubmit="handleMagicLinkLogin(event)" novalidate>
                    <p style="font-size: 14px; color: #71717a; margin-bottom: 16px; line-height: 1.5;">Nhập email của bạn, chúng tôi sẽ gửi một liên kết đăng nhập an toàn để bạn truy cập ngay lập tức.</p>
                    <div class="auth-field">
                        <label for="MagicEmail">Email</label>
                        <input id="MagicEmail" type="email" autocomplete="email" placeholder="ban@example.com" required />
                        <span id="MagicEmailError" style="display: none; color: #dc2626; font-size: 0.82rem; margin-top: 4px;">Vui lòng nhập địa chỉ email hợp lệ.</span>
                    </div>
                    <button type="submit" class="auth-submit-button" id="btnSendMagicLink">Gửi link đăng nhập</button>
                </form>
                <div style="margin-top: 16px; text-align: center;">
                    <button type="button" onclick="showPasswordAuth()" style="background: none; border: none; color: #18181b; font-weight: 600; font-size: 14px; cursor: pointer; text-decoration: underline;">Quay lại đăng nhập bằng mật khẩu</button>
                </div>
            </div>

            <div id="phoneAuthFormContainer" style="display: none;">
                <div id="phoneStep1">
                    <form id="phoneAuthForm" class="auth-form" onsubmit="handleSendPhoneOTP(event)" novalidate>
                        <p style="font-size: 14px; color: #71717a; margin-bottom: 16px; line-height: 1.5;">Nhập số điện thoại của bạn để nhận mã OTP gồm 6 chữ số.</p>
                        <div class="auth-field">
                            <label for="PhoneNumber">Số điện thoại</label>
                            <input id="PhoneNumber" type="tel" autocomplete="tel" placeholder="0912345678" required />
                            <span id="PhoneNumberError" style="display: none; color: #dc2626; font-size: 0.82rem; margin-top: 4px;">Vui lòng nhập số điện thoại hợp lệ.</span>
                        </div>
                        <div id="recaptcha-container"></div>
                        <button type="submit" class="auth-submit-button" id="btnSendOTP">Gửi mã SMS</button>
                    </form>
                </div>
                <div id="phoneStep2" style="display: none;">
                    <form id="otpAuthForm" class="auth-form" onsubmit="handleVerifyOTP(event)" novalidate>
                        <p style="font-size: 14px; color: #71717a; margin-bottom: 16px; line-height: 1.5;">Mã OTP đã được gửi. Vui lòng kiểm tra tin nhắn.</p>
                        <div class="auth-field">
                            <label for="OTPCode">Mã OTP</label>
                            <input id="OTPCode" type="number" placeholder="123456" required />
                            <span id="OTPCodeError" style="display: none; color: #dc2626; font-size: 0.82rem; margin-top: 4px;">Vui lòng nhập mã OTP.</span>
                        </div>
                        <button type="submit" class="auth-submit-button" id="btnVerifyOTP">Xác nhận & Đăng nhập</button>
                    </form>
                </div>
                <div style="margin-top: 16px; text-align: center;">
                    <button type="button" onclick="showPasswordAuth()" style="background: none; border: none; color: #18181b; font-weight: 600; font-size: 14px; cursor: pointer; text-decoration: underline;">Quay lại đăng nhập bằng mật khẩu</button>
                </div>
            </div>

            <p class="auth-legal">
                Khi tiếp tục, bạn đồng ý với
                <a href="/terms">Điều khoản sử dụng</a>
                và
                <a href="/Home/Privacy">Chính sách bảo mật</a>.
            </p>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function handleGoogleLogin() {
            const errorDiv = document.getElementById("authErrorMessage");
            if (!window.firebaseAuthHelpers) {
                errorDiv.innerText = "Firebase chưa được tải xong. Vui lòng tải lại trang.";
                errorDiv.style.display = "block";
                return;
            }
            const btns = document.querySelectorAll('.auth-social-button');
            btns.forEach(b => b.disabled = true);

            window.firebaseAuthHelpers.signInWithGoogle()
                .then(result => {
                    return window.firebaseAuthHelpers.syncWithBackend(result.user, '@ViewData["ReturnUrl"]');
                })
                .catch(error => {
                    btns.forEach(b => b.disabled = false);
                    if (error.code === 'auth/popup-closed-by-user' || error.code === 'auth/cancelled-popup-request') {
                        return; // Bỏ qua mượt mà
                    }
                    
                    const errorDiv = document.getElementById("authErrorMessage");
                    if (error.isBackend) {
                        errorDiv.innerText = "Lỗi hệ thống: " + error.message;
                    } else {
                        errorDiv.innerText = "Lỗi đăng nhập Google: " + error.message;
                    }
                    errorDiv.style.display = "block";
                });
        }

        function handleFacebookLogin() {
            const errorDiv = document.getElementById("authErrorMessage");
            if (!window.firebaseAuthHelpers) {
                errorDiv.innerText = "Firebase chưa được tải xong. Vui lòng tải lại trang.";
                errorDiv.style.display = "block";
                return;
            }
            const btns = document.querySelectorAll('.auth-social-button');
            btns.forEach(b => b.disabled = true);

            window.firebaseAuthHelpers.signInWithFacebook()
                .then(result => {
                    return window.firebaseAuthHelpers.syncWithBackend(result.user, '@ViewData["ReturnUrl"]');
                })
                .catch(error => {
                    btns.forEach(b => b.disabled = false);
                    if (error.code === 'auth/popup-closed-by-user' || error.code === 'auth/cancelled-popup-request') {
                        return; // Bỏ qua mượt mà
                    }
                    
                    const errorDiv = document.getElementById("authErrorMessage");
                    if (error.isBackend) {
                        errorDiv.innerText = "Lỗi hệ thống: " + error.message;
                    } else {
                        errorDiv.innerText = "Lỗi đăng nhập Facebook: " + error.message;
                    }
                    errorDiv.style.display = "block";
                });
        }

        function handleEmailLogin(event) {
            event.preventDefault();
            if (typeof $ !== 'undefined' && $.validator && $.validator.unobtrusive) {
                if (!$(event.target).valid()) return;
            } else if (!event.target.checkValidity()) {
                event.target.reportValidity();
                return;
            }
            
            const errorDiv = document.getElementById("authErrorMessage");
            if (errorDiv) errorDiv.style.display = "none";
            
            if (!window.firebaseAuthHelpers) return;

            const email = document.getElementById("Email").value;
            const password = document.getElementById("Password").value;
            const returnUrl = '@ViewData["ReturnUrl"]';

            const btn = document.querySelector(".auth-submit-button");
            btn.innerText = "Đang đăng nhập...";
            btn.disabled = true;

            window.firebaseAuthHelpers.signInWithEmail(email, password)
                .then(result => {
                    return window.firebaseAuthHelpers.syncWithBackend(result.user, returnUrl);
                })
                .catch(error => {
                    btn.innerText = "Đăng nhập";
                    btn.disabled = false;
                    
                    const errorDiv = document.getElementById("authErrorMessage");
                    if (error.isBackend) {
                        errorDiv.innerText = "Đăng nhập thất bại: " + error.message;
                    } else if (error.code === 'auth/invalid-credential' || error.code === 'auth/user-not-found' || error.code === 'auth/wrong-password') {
                        errorDiv.innerText = "Email hoặc mật khẩu không chính xác.";
                    } else {
                        errorDiv.innerText = "Lỗi đăng nhập: " + error.message;
                    }
                    errorDiv.style.display = "block";
                });
        }

        function clearAuthError() {
            const errorDiv = document.getElementById("authErrorMessage");
            if (errorDiv) errorDiv.style.display = "none";
        }

        function showPasswordAuth() {
            clearAuthError();
            document.getElementById('passwordFormContainer').style.display = 'block';
            document.getElementById('magicLinkFormContainer').style.display = 'none';
            document.getElementById('phoneAuthFormContainer').style.display = 'none';
        }

        function showMagicLinkAuth() {
            clearAuthError();
            document.getElementById('passwordFormContainer').style.display = 'none';
            document.getElementById('magicLinkFormContainer').style.display = 'block';
            document.getElementById('phoneAuthFormContainer').style.display = 'none';
        }

        function showPhoneAuth() {
            clearAuthError();
            document.getElementById('passwordFormContainer').style.display = 'none';
            document.getElementById('magicLinkFormContainer').style.display = 'none';
            document.getElementById('phoneAuthFormContainer').style.display = 'block';
            
            // Khởi tạo Recaptcha vô hình nếu chưa khởi tạo
            if (window.firebaseAuthHelpers && !window.recaptchaVerifier) {
                window.firebaseAuthHelpers.setupRecaptcha('recaptcha-container');
            }
        }

        function handleSendPhoneOTP(event) {
            event.preventDefault();
            
            const phoneInput = document.getElementById("PhoneNumber");
            const phoneError = document.getElementById("PhoneNumberError");
            if (!phoneInput.value.trim()) {
                phoneError.style.display = "block";
                phoneInput.style.borderColor = "#dc2626";
                return;
            } else {
                phoneError.style.display = "none";
                phoneInput.style.borderColor = "";
            }
            
            const errorDiv = document.getElementById("authErrorMessage");
            if (errorDiv) errorDiv.style.display = "none";
            
            if (!window.firebaseAuthHelpers) return;

            let phone = document.getElementById("PhoneNumber").value.trim();
            // Tự động thêm +84 nếu người dùng nhập số 0 ở đầu
            if (phone.startsWith("0")) {
                phone = "+84" + phone.substring(1);
            } else if (!phone.startsWith("+")) {
                phone = "+84" + phone; // Giả định là VN
            }

            const btn = document.getElementById("btnSendOTP");
            btn.innerText = "Đang gửi...";
            btn.disabled = true;

            window.firebaseAuthHelpers.requestPhoneOTP(phone)
                .then((confirmationResult) => {
                    document.getElementById("phoneStep1").style.display = 'none';
                    document.getElementById("phoneStep2").style.display = 'block';
                })
                .catch((error) => {
                    console.error(error);
                    const errorDiv = document.getElementById("authErrorMessage");
                    if (errorDiv) {
                        errorDiv.innerText = "Lỗi gửi SMS: " + error.message;
                        errorDiv.style.display = "block";
                    }
                    btn.innerText = "Gửi mã SMS";
                    btn.disabled = false;
                });
        }

        function handleVerifyOTP(event) {
            event.preventDefault();
            
            const codeInput = document.getElementById("OTPCode");
            const codeError = document.getElementById("OTPCodeError");
            if (!codeInput.value.trim()) {
                codeError.style.display = "block";
                codeInput.style.borderColor = "#dc2626";
                return;
            } else {
                codeError.style.display = "none";
                codeInput.style.borderColor = "";
            }
            
            const errorDiv = document.getElementById("authErrorMessage");
            if (errorDiv) errorDiv.style.display = "none";
            
            if (!window.firebaseAuthHelpers) return;

            const code = document.getElementById("OTPCode").value;
            const btn = document.getElementById("btnVerifyOTP");
            btn.innerText = "Đang xác thực...";
            btn.disabled = true;

            window.firebaseAuthHelpers.verifyPhoneOTP(code)
                .then((result) => {
                    const returnUrl = '@ViewData["ReturnUrl"]';
                    return window.firebaseAuthHelpers.syncWithBackend(result.user, returnUrl, { phoneNumber: result.user.phoneNumber });
                })
                .catch((error) => {
                    console.error(error);
                    btn.innerText = "Xác nhận & Đăng nhập";
                    btn.disabled = false;
                    
                    const errorDiv = document.getElementById("authErrorMessage");
                    if (errorDiv) {
                        if (error.isBackend) {
                            errorDiv.innerText = "Đăng nhập thất bại: " + error.message;
                        } else {
                            errorDiv.innerText = "Mã OTP không chính xác hoặc đã hết hạn.";
                        }
                        errorDiv.style.display = "block";
                    }
                });
        }

        function handleMagicLinkLogin(event) {
            event.preventDefault();
            
            const emailInput = document.getElementById("MagicEmail");
            const emailError = document.getElementById("MagicEmailError");
            if (!emailInput.value.trim() || !emailInput.checkValidity()) {
                emailError.style.display = "block";
                emailInput.style.borderColor = "#dc2626";
                return;
            } else {
                emailError.style.display = "none";
                emailInput.style.borderColor = "";
            }
            
            const errorDiv = document.getElementById("authErrorMessage");
            if (errorDiv) errorDiv.style.display = "none";
            
            if (!window.firebaseAuthHelpers) return;

            const email = document.getElementById("MagicEmail").value;
            const btn = document.getElementById("btnSendMagicLink");
            btn.innerText = "Đang gửi...";
            btn.disabled = true;

            const sessionId = typeof crypto.randomUUID === "function" 
                ? crypto.randomUUID() 
                : Math.random().toString(36).substring(2) + Date.now().toString(36);
            
            const url = new URL(window.location.href);
            url.searchParams.set('sessionId', sessionId);
            const redirectUrl = url.toString();

            window.firebaseAuthHelpers.sendEmailLink(email, redirectUrl)
                .then(() => {
                    const successDiv = document.getElementById("authSuccessMessage");
                    if (successDiv) {
                        successDiv.innerText = "Link đăng nhập đã được gửi tới " + email + ". Vui lòng kiểm tra hộp thư của bạn! (Mẹo: Mở link trên thiết bị khác cũng sẽ tự đăng nhập trình duyệt này)";
                        successDiv.style.display = "block";
                    }
                    btn.innerText = "Đang chờ xác thực...";
                    
                    const pollInterval = setInterval(() => {
                        fetch(`/Account/PollMagicLinkSession?sessionId=${sessionId}&returnUrl=${encodeURIComponent('@ViewData["ReturnUrl"]' || '/')}`)
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    clearInterval(pollInterval);
                                    btn.innerText = "Đăng nhập thành công!";
                                    window.location.href = data.returnUrl;
                                }
                            });
                    }, 2000);

                    // Stop polling after 15 minutes (matches backend MemoryCache expiration)
                    setTimeout(() => {
                        clearInterval(pollInterval);
                        if (btn.innerText === "Đang chờ xác thực...") {
                            btn.innerText = "Phiên đăng nhập hết hạn";
                            btn.disabled = false;
                        }
                    }, 15 * 60 * 1000);
                })
                .catch(error => {
                    const errorDiv = document.getElementById("authErrorMessage");
                    if (errorDiv) {
                        errorDiv.innerText = "Có lỗi xảy ra: " + error.message;
                        errorDiv.style.display = "block";
                    }
                    btn.innerText = "Gửi link đăng nhập";
                    btn.disabled = false;
                });
        }

        document.addEventListener("DOMContentLoaded", () => {
            const checkFirebase = setInterval(() => {
                if (window.firebaseAuthHelpers) {
                    clearInterval(checkFirebase);
                    checkMagicLinkCallback();
                }
            }, 100);
        });

        function checkMagicLinkCallback() {
            if (window.firebaseAuthHelpers.checkIsSignInWithEmailLink(window.location.href)) {
                const returnUrl = '@ViewData["ReturnUrl"]';
                
                // Hiển thị loading trong form-shell
                const shell = document.querySelector('.auth-form-shell');
                if (shell) {
                    shell.innerHTML = `
                        <div style="text-align: center; padding: 40px 0;">
                            <h2 style="font-size: 20px; margin-bottom: 8px;">Đang xác thực liên kết...</h2>
                            <p style="color: #71717a;">Vui lòng đợi trong giây lát.</p>
                        </div>
                    `;
                }

                let fallbackEmail = null;
                if (!window.localStorage.getItem('emailForSignIn')) {
                    fallbackEmail = window.prompt('Để bảo mật, vui lòng xác nhận email của bạn:');
                }

                window.firebaseAuthHelpers.completeEmailLinkSignIn(window.location.href, fallbackEmail)
                    .then(result => {
                        if (result) {
                            const urlObj = new URL(window.location.href);
                            const sessionId = urlObj.searchParams.get('sessionId');
                            
                            // Hiển thị thông báo trên thiết bị phụ (ví dụ điện thoại) nếu là Cross-device
                            if (sessionId) {
                                const shell = document.querySelector('.auth-form-shell');
                                if (shell) {
                                    shell.innerHTML = `
                                        <div style="text-align: center; padding: 40px 0;">
                                            <h2 style="font-size: 20px; margin-bottom: 8px; color: #10b981;">Xác thực thành công!</h2>
                                            <p style="color: #71717a; margin-bottom: 24px;">Máy tính của bạn đã được đăng nhập. Bạn có thể đóng trang này hoặc tiếp tục duyệt web tại đây.</p>
                                        </div>
                                    `;
                                }
                            }
                            
                            window.firebaseAuthHelpers.syncWithBackend(result.user, returnUrl, { sessionId: sessionId });
                        }
                    })
                    .catch(error => {
                        const errorDiv = document.getElementById("authErrorMessage");
                        if (errorDiv) {
                            if (error.message === "EMAIL_REQUIRED" || error.message.includes("EMAIL_REQUIRED")) {
                                errorDiv.innerText = "Xác thực thất bại: Không có email để xác thực.";
                            } else {
                                errorDiv.innerText = "Lỗi xác thực: Link đã hết hạn hoặc không hợp lệ. (" + error.message + ")";
                            }
                            errorDiv.style.display = "block";
                        }
                        const shell = document.querySelector('.auth-form-shell');
                        if (shell && !errorDiv) {
                            alert("Lỗi xác thực: Link đã hết hạn hoặc không hợp lệ.");
                        } else {
                            setTimeout(() => { window.location.href = "/Account/Login"; }, 3000);
                        }
                    });
            }
        }
    </script>
}
