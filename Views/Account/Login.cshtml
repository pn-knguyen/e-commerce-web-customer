@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_AuthLayout";
}

<div class="auth-page">
    <section class="auth-brand-panel" aria-labelledby="brand-heading">
        <a class="auth-home-link" asp-controller="Home" asp-action="Index" aria-label="Về trang chủ TechStore">
            <img src="~/images/logo-techstore.svg" alt="TechStore" width="250" height="75" />
        </a>

        <div class="auth-brand-copy">
            <p class="auth-eyebrow">TechStore membership</p>
            <h1 id="brand-heading">Công nghệ cho cuộc sống.</h1>
            <p>Mua sắm nhanh hơn, quản lý đơn hàng gọn hơn và nhận ưu đãi dành riêng cho bạn.</p>
        </div>

        <div class="auth-promises" aria-label="Cam kết của TechStore">
            <span>Chính hãng 100%</span>
            <span>Giao nhanh toàn quốc</span>
            <span>Đổi trả minh bạch</span>
        </div>

        <img class="auth-brand-watermark" src="~/images/logo-techstore-icon.svg" alt="" aria-hidden="true" />
    </section>

    <section class="auth-form-panel" aria-labelledby="login-heading">
        <div class="auth-form-shell">
            <div class="auth-switch">
                <span>Chưa có tài khoản?</span>
                <a asp-controller="Account" asp-action="Register">Đăng ký</a>
            </div>

            <header class="auth-form-header">
                <p class="auth-form-kicker">Chào mừng trở lại</p>
                <h2 id="login-heading">Đăng nhập TechStore</h2>
                <p>Tiếp tục hành trình mua sắm của bạn.</p>
            </header>

            @if (TempData["AuthNotice"] is string notice)
            {
                <div class="auth-notice" role="status">@notice</div>
            }

            @if (TempData["AuthSuccess"] is string success)
            {
                <div class="auth-success-alert" role="status">@success</div>
            }

            <div class="auth-social-grid">
                <a class="auth-social-button" asp-action="ExternalLogin" asp-route-provider="Google">
                    <span class="social-icon-wrap" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                    </span>
                    <span>Google</span>
                </a>
                <a class="auth-social-button" asp-action="ExternalLogin" asp-route-provider="Facebook">
                    <span class="social-icon-wrap social-icon-facebook" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="#1877F2"/>
                            <path d="M16.671 15.543l.532-3.47h-3.328v-2.25c0-.949.465-1.874 1.956-1.874h1.513V4.996s-1.374-.235-2.686-.235c-2.741 0-4.533 1.662-4.533 4.669v2.643H7.078v3.47h3.047v8.385a12.09 12.09 0 003.75 0v-8.385h2.796z" fill="#ffffff"/>
                        </svg>
                    </span>
                    <span>Facebook</span>
                </a>
            </div>

            <div class="auth-divider"><span>hoặc đăng nhập bằng email</span></div>

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary" role="alert"></div>

                <div class="auth-field">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" type="email" autocomplete="email" placeholder="ban@example.com" />
                    <span asp-validation-for="Email"></span>
                </div>

                <div class="auth-field">
                    <div class="auth-label-row">
                        <label asp-for="Password"></label>
                        <a asp-action="ForgotPassword" class="auth-forgot-link">Quên mật khẩu?</a>
                    </div>
                    <div class="auth-password-control">
                        <input asp-for="Password" autocomplete="current-password" placeholder="Nhập mật khẩu" />
                        <button type="button" class="auth-password-toggle" data-password-toggle="Password" aria-label="Hiện mật khẩu">Hiện</button>
                    </div>
                    <span asp-validation-for="Password"></span>
                </div>

                <label class="auth-checkbox">
                    <input asp-for="RememberMe" />
                    <span>Ghi nhớ đăng nhập trên thiết bị này</span>
                </label>

                <button type="submit" class="auth-submit-button">Đăng nhập</button>
            </form>

            <p class="auth-legal">
                Khi tiếp tục, bạn đồng ý với
                <a href="/terms">Điều khoản sử dụng</a>
                và
                <a href="/Home/Privacy">Chính sách bảo mật</a>.
            </p>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
