@model AccountOrderDetailViewModel

@{
    ViewData["Title"] = $"Chi tiết đơn hàng {Model.OrderCode}";
    ViewData["MetaDescription"] = $"Theo dõi thông tin chi tiết của đơn hàng {Model.OrderCode}.";
}

<section class="account-profile-page">
    <div class="account-profile-shell">
        <partial name="_AccountProfileHeader" model="Model.Summary" />

        <div class="ap-layout">
            <partial name="_AccountProfileSidebar" model="AccountProfileTabs.History" />

            <div class="ap-main">
                <div class="order-detail-shell">
                    <nav class="od-breadcrumb" aria-label="Đường dẫn">
                        <a asp-controller="Account" asp-action="Profile" asp-route-tab="@AccountProfileTabs.History">
                            <svg aria-hidden="true"><use href="#hero-icon-chevron-left"></use></svg>
                            Lịch sử mua hàng
                        </a>
                        <span aria-hidden="true">/</span>
                        <strong>Chi tiết đơn hàng</strong>
                    </nav>

                    @if (TempData["PaymentError"] is string paymentError)
                    {
                        <div class="od-flash-error" role="alert" style="background-color: #fef2f2; border: 1px solid #ef4444; color: #b91c1c; padding: 12px 16px; border-radius: 8px; margin-bottom: 24px; font-weight: 500;">
                            <svg aria-hidden="true" style="width: 20px; height: 20px; display: inline-block; vertical-align: text-bottom; margin-right: 6px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                            @paymentError
                        </div>
                    }

                    <section class="od-card od-overview" aria-labelledby="order-overview-title">
                        <h1 id="order-overview-title">Tổng quan</h1>
                        <div class="od-order-meta">
                            <span>Đơn hàng: <strong>@Model.OrderCode</strong></span>
                            <i aria-hidden="true"></i>
                            <span>Ngày đặt hàng: <strong>@Model.OrderedDateText</strong></span>
                            <i aria-hidden="true"></i>
                            <mark class="od-status od-status--@Model.StatusTone">@Model.StatusText</mark>
                        </div>

                        <div class="od-items">
                            @foreach (var item in Model.Items)
                            {
                                <article class="od-item">
                                    <img src="@item.ProductImageUrl" alt="@item.ProductImageAlt" width="42" height="42" loading="lazy" />
                                    <div class="od-item-main">
                                        <h2>@item.ProductName</h2>
                                        <strong>@item.UnitPriceText</strong>
                                        @if (!string.IsNullOrWhiteSpace(item.ColorText))
                                        {
                                            <p><span>@item.ColorText</span></p>
                                        }
                                    </div>
                                    <div class="od-item-actions">
                                        <span>Số lượng: <strong>@item.Quantity</strong></span>
                                        <button type="button">Mua lại</button>
                                    </div>
                                </article>
                            }
                        </div>
                    </section>

                    <section class="od-card od-stepper" aria-label="Trạng thái đơn hàng">
                        @for (var index = 0; index < Model.Steps.Count; index++)
                        {
                            var step = Model.Steps[index];
                            <div class="od-step @(step.IsDone ? "is-done" : null)">
                                <span>@(step.IsDone ? "✓" : (index + 1).ToString())</span>
                                <strong>@step.Label</strong>
                            </div>
                        }
                    </section>

                    <section class="od-card od-shipment-card" aria-labelledby="order-shipment-title">
                        <div class="od-shipment-header">
                            <div>
                                <span class="od-section-kicker">Theo dõi vận chuyển</span>
                                <h2 id="order-shipment-title">@Model.Shipment.StatusText</h2>
                                <p>@Model.Shipment.UpdatedAtText</p>
                            </div>
                            <mark class="od-shipment-status od-shipment-status--@Model.Shipment.StatusTone">
                                @Model.Shipment.StatusText
                            </mark>
                        </div>

                        @if (!Model.Shipment.HasShipment)
                        {
                            <div class="od-shipment-empty">
                                <span aria-hidden="true">1</span>
                                <div>
                                    <strong>Cửa hàng đang xử lý đơn hàng</strong>
                                    <p>Vận đơn GHN chưa được tạo. Trạng thái sẽ tự xuất hiện tại đây sau khi cửa hàng bàn giao đơn cho đơn vị vận chuyển.</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <dl class="od-shipment-meta">
                                <div>
                                    <dt>Đơn vị vận chuyển</dt>
                                    <dd>@Model.Shipment.ProviderName</dd>
                                </div>
                                <div>
                                    <dt>Mã vận đơn</dt>
                                    <dd>@(string.IsNullOrWhiteSpace(Model.Shipment.TrackingCode) ? "Đang cập nhật" : Model.Shipment.TrackingCode)</dd>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(Model.Shipment.TrackingUrl))
                                {
                                    <div class="od-shipment-track-action">
                                        <dt>Theo dõi trên GHN</dt>
                                        <dd>
                                            <a href="@Model.Shipment.TrackingUrl" target="_blank" rel="noopener noreferrer">
                                                Mở trang theo dõi
                                                <svg aria-hidden="true"><use href="#profile-icon-external"></use></svg>
                                            </a>
                                        </dd>
                                    </div>
                                }
                            </dl>

                            @if (!string.IsNullOrWhiteSpace(Model.Shipment.FailureReason))
                            {
                                <div class="od-shipment-warning" role="alert">
                                    <strong>Cần lưu ý</strong>
                                    <span>@Model.Shipment.FailureReason</span>
                                </div>
                            }

                            <div class="od-shipment-timeline">
                                @if (Model.Shipment.Events.Count == 0)
                                {
                                    <div class="od-shipment-event is-current">
                                        <i class="od-shipment-dot od-shipment-dot--@Model.Shipment.StatusTone" aria-hidden="true"></i>
                                        <div>
                                            <strong>@Model.Shipment.StatusText</strong>
                                            <time>@Model.Shipment.UpdatedAtText</time>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    @for (var index = 0; index < Model.Shipment.Events.Count; index++)
                                    {
                                        var shipmentEvent = Model.Shipment.Events[index];
                                        <article class="od-shipment-event @(index == 0 ? "is-current" : null)">
                                            <i class="od-shipment-dot od-shipment-dot--@shipmentEvent.StatusTone" aria-hidden="true"></i>
                                            <div>
                                                <div class="od-shipment-event-title">
                                                    <strong>@shipmentEvent.StatusText</strong>
                                                    <time>@shipmentEvent.OccurredAtText</time>
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(shipmentEvent.Message))
                                                {
                                                    <p>@shipmentEvent.Message</p>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(shipmentEvent.DriverText))
                                                {
                                                    <span class="od-shipment-driver">@shipmentEvent.DriverText</span>
                                                }
                                            </div>
                                        </article>
                                    }
                                }
                            </div>
                        }
                    </section>

                    <div class="od-detail-grid">
                        <div class="od-left-column">
                            <section class="od-card od-info-card" aria-labelledby="order-customer-title">
                                <h2 id="order-customer-title">Thông tin khách hàng</h2>
                                <dl class="od-info-list">
                                    <div>
                                        <dt>Họ và tên:</dt>
                                        <dd>@Model.Customer.FullName</dd>
                                    </div>
                                    <div>
                                        <dt>Số điện thoại:</dt>
                                        <dd>@Model.Customer.PhoneNumber</dd>
                                    </div>
                                    <div>
                                        <dt>Địa chỉ:</dt>
                                        <dd>@Model.Customer.AddressText</dd>
                                    </div>
                                    <div>
                                        <dt>Ghi chú:</dt>
                                        <dd>@Model.Customer.NoteText</dd>
                                    </div>
                                </dl>
                            </section>

                            <section class="od-card od-support-card" aria-labelledby="order-support-title">
                                <h2 id="order-support-title">Thông tin hỗ trợ</h2>
                                <div class="od-support-list">
                                    <div class="od-support-row">
                                        <svg aria-hidden="true"><use href="#profile-icon-pin"></use></svg>
                                        <div>
                                            <span>Địa chỉ cửa hàng:</span>
                                            <strong>@Model.Support.StoreAddress</strong>
                                        </div>
                                        <a href="https://www.google.com/maps/search/?api=1&query=@Uri.EscapeDataString(Model.Support.StoreAddress)" target="_blank" rel="noopener">
                                            <svg aria-hidden="true"><use href="#profile-icon-pin"></use></svg>
                                            Chỉ đường
                                        </a>
                                    </div>
                                    <div class="od-support-row">
                                        <svg aria-hidden="true"><use href="#hero-icon-phone"></use></svg>
                                        <div>
                                            <span>Số điện thoại:</span>
                                            <strong>@Model.Support.StorePhone</strong>
                                        </div>
                                        <a href="tel:@Model.Support.StorePhone">
                                            <svg aria-hidden="true"><use href="#hero-icon-phone"></use></svg>
                                            Liên hệ
                                        </a>
                                    </div>
                                    <a class="od-zalo-link" href="@Model.Support.ZaloUrl" target="_blank" rel="noopener">
                                        <span>Zalo</span>
                                        Liên hệ qua Zalo
                                        <svg aria-hidden="true"><use href="#profile-icon-external"></use></svg>
                                    </a>
                                </div>
                            </section>
                        </div>

                        <section class="od-card od-payment-card" aria-labelledby="order-payment-title">
                            <h2 id="order-payment-title">Thông tin thanh toán</h2>
                            <div class="od-payment-section">
                                <h3>Sản phẩm</h3>
                                <dl>
                                    <div>
                                        <dt>Số lượng sản phẩm:</dt>
                                        <dd>@Model.Payment.ProductQuantity</dd>
                                    </div>
                                    <div>
                                        <dt>Tổng tiền hàng:</dt>
                                        <dd>@Model.Payment.SubtotalText</dd>
                                    </div>
                                    <div>
                                        <dt>Giảm giá:</dt>
                                        <dd class="@(Model.Payment.HasDiscount ? "is-discount" : null)">@Model.Payment.DiscountText</dd>
                                    </div>
                                    <div>
                                        <dt>Phí vận chuyển:</dt>
                                        <dd class="@(Model.Payment.IsFreeShipping ? "is-free" : null)">@Model.Payment.ShippingFeeText</dd>
                                    </div>
                                </dl>
                            </div>

                            <div class="od-payment-section od-payment-section--total">
                                <h3>Thanh toán</h3>
                                <dl>
                                    <div>
                                        <dt>
                                            Tổng số tiền
                                            <small>(Đã bao gồm VAT và được làm tròn)</small>
                                        </dt>
                                        <dd class="is-total">@Model.Payment.TotalText</dd>
                                    </div>
                                    <div>
                                        <dt>
                                            Tổng số tiền đã thanh toán
                                            <small>(Đã thanh toán trước)</small>
                                        </dt>
                                        <dd>@Model.Payment.PaidText</dd>
                                    </div>
                                    <div>
                                        <dt>
                                            Tổng số tiền còn lại
                                            <small>(Cần phải thanh toán thêm)</small>
                                        </dt>
                                        <dd class="is-total">@Model.Payment.RemainingText</dd>
                                    </div>
                                </dl>


                            </div>
                        </section>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <partial name="_AccountProfileMobileNav" model="AccountProfileTabs.History" />
</section>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/account-profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/account-order-detail.css" asp-append-version="true" />
}
