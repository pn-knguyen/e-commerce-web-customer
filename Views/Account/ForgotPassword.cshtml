@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_AuthLayout";
}

<div class="auth-page">
    <section class="auth-brand-panel" aria-labelledby="brand-heading">
        <a class="auth-home-link" asp-controller="Home" asp-action="Index" aria-label="Về trang chủ TechStore">
            <img src="~/images/logo-techstore.svg" alt="TechStore" width="250" height="75" />
        </a>

        <div class="auth-brand-copy">
            <p class="auth-eyebrow">Khôi phục mật khẩu</p>
            <h1 id="brand-heading">Đừng lo lắng.</h1>
            <p>Chúng tôi sẽ giúp bạn lấy lại quyền truy cập vào tài khoản của mình một cách nhanh chóng và an toàn.</p>
        </div>

        <div class="auth-promises" aria-label="Cam kết của TechStore">
            <span>Bảo mật tuyệt đối</span>
            <span>Khôi phục nhanh chóng</span>
            <span>Hỗ trợ 24/7</span>
        </div>

        <img class="auth-brand-watermark" src="~/images/logo-techstore-icon.svg" alt="" aria-hidden="true" />
    </section>

    <section class="auth-form-panel" aria-labelledby="forgot-heading">
        <div class="auth-form-shell">
            <div class="auth-switch">
                <span>Bạn đã nhớ lại mật khẩu?</span>
                <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
            </div>

            <header class="auth-form-header">
                <p class="auth-form-kicker">TechStore Account</p>
                <h2 id="forgot-heading">Quên mật khẩu</h2>
                <p>Nhập email của bạn để nhận liên kết đặt lại mật khẩu.</p>
            </header>

            <div id="forgotPasswordFormContainer">
                <form id="forgotPasswordForm" class="auth-form" onsubmit="handleForgotPassword(event)">
                    <div id="form-error-summary" class="auth-validation-summary" role="alert" style="display: none; color: #dc2626; margin-bottom: 16px;"></div>
                    <div id="form-success-summary" class="auth-success-alert" role="status" style="display: none; color: #16a34a; background: #f0fdf4; border: 1px solid #bbf7d0; padding: 12px; border-radius: 8px; margin-bottom: 16px;"></div>

                    <div class="auth-field">
                        <label for="Email">Địa chỉ Email</label>
                        <input id="Email" name="Email" type="email" autocomplete="email" placeholder="ban@example.com" required />
                    </div>

                    <button type="submit" class="auth-submit-button" style="margin-top: 16px;">Gửi email khôi phục</button>
                </form>
            </div>

            <p class="auth-legal" style="margin-top: 32px;">
                Cần hỗ trợ thêm?
                <a href="/Home/Contact">Liên hệ chăm sóc khách hàng</a>.
            </p>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        function handleForgotPassword(event) {
            event.preventDefault();
            
            const emailInput = document.getElementById("Email");
            const errorSummary = document.getElementById("form-error-summary");
            
            if (!emailInput.value.trim() || !emailInput.checkValidity()) {
                errorSummary.innerText = "Vui lòng nhập địa chỉ email hợp lệ.";
                errorSummary.style.display = 'block';
                emailInput.style.borderColor = "#dc2626";
                return;
            } else {
                errorSummary.style.display = 'none';
                emailInput.style.borderColor = "";
            }

            if (!window.firebaseAuthHelpers) {
                alert("Firebase chưa được tải xong. Vui lòng tải lại trang.");
                return;
            }

            const email = emailInput.value.trim();
            const btn = document.querySelector(".auth-submit-button");
            const successSummary = document.getElementById("form-success-summary");

            // Giao diện load state
            btn.innerText = "Đang gửi email...";
            btn.disabled = true;
            errorSummary.style.display = 'none';
            successSummary.style.display = 'none';

            const continueUrl = window.location.origin + '/Account/Login';

            window.firebaseAuthHelpers.sendPasswordReset(email, continueUrl)
                .then(() => {
                    btn.innerText = "Gửi email khôi phục";
                    btn.disabled = false;
                    document.getElementById("Email").value = "";
                    successSummary.innerText = "Đã gửi email khôi phục thành công! Vui lòng kiểm tra Hộp thư đến (hoặc thư mục Spam) của bạn.";
                    successSummary.style.display = 'block';
                })
                .catch(error => {
                    btn.innerText = "Gửi email khôi phục";
                    btn.disabled = false;
                    errorSummary.style.display = 'block';
                    
                    if (error.code === 'auth/user-not-found') {
                        errorSummary.innerText = "Không tìm thấy tài khoản nào với địa chỉ email này.";
                    } else if (error.code === 'auth/invalid-email') {
                        errorSummary.innerText = "Địa chỉ email không hợp lệ.";
                    } else if (error.code === 'auth/too-many-requests') {
                        errorSummary.innerText = "Bạn đã yêu cầu quá nhiều lần. Vui lòng thử lại sau.";
                    } else {
                        errorSummary.innerText = "Lỗi: " + error.message;
                    }
                });
        }
    </script>
}
