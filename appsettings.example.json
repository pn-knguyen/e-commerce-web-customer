{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=YOUR_DATABASE;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "DatabaseSettings": {
    "UseMockData": true,
    "UseMockData_Comment": "True: Sử dụng dữ liệu giả lập (Mock/In-memory) khi clone dự án về, chạy không cần database. False: Kết nối và truy vấn trực tiếp từ cơ sở dữ liệu thật (EF Core / DbContext / Identity)."
  },
  "Cloudinary": {
    "CloudName": "YOUR_CLOUD_NAME",
    "ApiKey": "YOUR_API_KEY",
    "ApiSecret": "YOUR_API_SECRET",
    "UploadPreset": "",
    "DefaultFolder": "ecommerce-admin",
    "MaxFileSizeInBytes": 5242880,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp",
      "image/gif",
      "image/svg+xml"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MoMo": {
    "PartnerCode": "MOMO",
    "AccessKey": "YOUR_ACCESS_KEY",
    "SecretKey": "YOUR_SECRET_KEY",
    "BaseUrl": "https://test-payment.momo.vn",
    "RequestType": "payWithMethod"
  },
  "SePayWebhook": {
    "IsTestMode": true,
    "AuthenticationMode": "HmacSha256",
    "ApiKey": "",
    "SecretKey": "YOUR_SEPAY_WEBHOOK_SECRET",
    "AllowedClockSkewSeconds": 300
  },
  "SePayPayment": {
    "BankCode": "Vietcombank",
    "BankName": "Vietcombank",
    "AccountNumber": "YOUR_TEST_ACCOUNT_NUMBER",
    "AccountName": "YOUR_TEST_ACCOUNT_NAME",
    "PaymentTimeoutMinutes": 15,
    "IsTestMode": true
  },
  "Gemini": {
    "ApiKey": "YOUR_GEMINI_API_KEY",
    "Model": "gemini-2.5-flash"
  },
  "CustomerMessages": {
    "HubUrl": "http://localhost:5081/hubs/customer-messages",
    "Jwt": {
      "Issuer": "TechStore.CustomerWeb",
      "AccessAudience": "TechStore.CustomerMessages",
      "AiReceiptAudience": "TechStore.CustomerMessages.AiReceipt",
      "SigningKey": "CHANGE_ME_MINIMUM_32_BYTES_LONG_SECRET",
      "AccessTokenMinutes": 60,
      "AiReceiptMinutes": 5
    }
  },
  "Firebase": {
    "ApiKey": "YOUR_FIREBASE_API_KEY",
    "AuthDomain": "YOUR_FIREBASE_AUTH_DOMAIN",
    "ProjectId": "YOUR_FIREBASE_PROJECT_ID",
    "StorageBucket": "YOUR_FIREBASE_STORAGE_BUCKET",
    "MessagingSenderId": "YOUR_FIREBASE_MESSAGING_SENDER_ID",
    "AppId": "YOUR_FIREBASE_APP_ID",
    "MeasurementId": "YOUR_FIREBASE_MEASUREMENT_ID"
  }
}
